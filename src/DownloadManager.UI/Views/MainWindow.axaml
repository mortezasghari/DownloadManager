<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:DownloadManager.UI.ViewModels"
        mc:Ignorable="d" d:DesignWidth="820" d:DesignHeight="540"
        x:Class="DownloadManager.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding Title}"
        Width="820" Height="540"
        WindowStartupLocation="CenterScreen">

  <DockPanel Margin="12">

    <!-- Command bar -->
    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,8">
      <TextBox Grid.Column="0"
               Text="{Binding NewUrl}"
               PlaceholderText="https://… (http/https only)"
               VerticalAlignment="Center" />
      <Button Grid.Column="1" Margin="8,0,0,0" Content="Add URL" Command="{Binding AddCommand}" />
      <Button Grid.Column="2" Margin="8,0,0,0" Content="Import list…" Command="{Binding ImportCommand}" />
    </Grid>

    <!-- Import summary (skip-with-reason surface) -->
    <Border DockPanel.Dock="Top"
            IsVisible="{Binding ImportSummary, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
            Background="#1F000000" CornerRadius="4" Padding="8" Margin="0,0,0,8">
      <TextBlock Text="{Binding ImportSummary}" FontFamily="monospace" TextWrapping="Wrap" />
    </Border>

    <!-- Download rows -->
    <ScrollViewer>
      <ItemsControl ItemsSource="{Binding Downloads}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:DownloadItemViewModel">
            <Border BorderBrush="#22000000" BorderThickness="0,0,0,1" Padding="6,8">
              <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">

                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding StatusText}" Opacity="0.8" />
                </StackPanel>

                <ProgressBar Grid.Row="1" Grid.Column="0" Margin="0,4"
                             Minimum="0" Maximum="100"
                             Value="{Binding ProgressPercent}"
                             IsIndeterminate="{Binding IsIndeterminate}" />

                <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Spacing="16" Opacity="0.75">
                  <TextBlock Text="{Binding SpeedText}" />
                  <TextBlock Text="{Binding EtaText}" />
                  <TextBlock Text="{Binding TargetPath}" TextTrimming="CharacterEllipsis" MaxWidth="360" />
                </StackPanel>

                <!-- Per-row commands: visibility reflects the state machine -->
                <StackPanel Grid.Row="0" Grid.RowSpan="3" Grid.Column="1"
                            Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                  <Button Content="Pause"  Command="{Binding PauseCommand}"  IsVisible="{Binding CanPause}" />
                  <Button Content="Resume" Command="{Binding ResumeCommand}" IsVisible="{Binding CanResume}" />
                  <Button Content="Retry"  Command="{Binding RetryCommand}"  IsVisible="{Binding CanRetry}" />
                  <Button Content="Re-auth…" Command="{Binding ReauthorizeCommand}" IsVisible="{Binding CanReauthorize}" />
                  <Button Content="Remove" Command="{Binding RemoveCommand}" />
                </StackPanel>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </DockPanel>

</Window>